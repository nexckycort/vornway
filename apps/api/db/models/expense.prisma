enum ExpenseType {
  STANDARD
  COMPOSITE
  SETTLEMENT
}

enum ExpenseStatus {
  ACTIVE
  DELETED
}

enum SettlementMethod {
  CARDS
  FLEX
}

model Expense {
  id          String   @id @default(cuid())
  groupId     String
  paidById    String // ID del GroupMember que pagó
  categoryId  String?
  description String
  amount      Float
  currency    String // Código de moneda: "COP", "USD", "EUR", etc.
  date        DateTime      @default(now())
  expenseType ExpenseType   @default(STANDARD)
  status      ExpenseStatus @default(ACTIVE)
  pinnedAt    DateTime?
  deletedAt   DateTime?
  deletedById String?
  settlementMethod SettlementMethod?
  notes       String?
  attachment  String? // URL de foto del recibo
  metadata    Json?

  group        Group                @relation(fields: [groupId], references: [id])
  category     ExpenseCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  paidBy       GroupMember          @relation("MemberPaidExpenses", fields: [paidById], references: [id])
  compositeItems CompositeExpenseItem[]
  payers       ExpensePayer[]
  participants ExpenseParticipant[]

  @@index([groupId, date(sort: Desc)])
  @@index([groupId, expenseType, status])
  @@index([groupId, pinnedAt(sort: Desc)])
  @@map("expense")
}

model ExpensePayer {
  id        String   @id @default(cuid())
  expenseId String
  memberId  String
  amount    Float

  expense Expense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  member  GroupMember @relation("MemberPaidExpenseAllocations", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([expenseId, memberId])
  @@index([expenseId])
  @@index([memberId])
  @@map("expense_payer")
}

model ExpenseParticipant {
  id        String @id @default(cuid())
  expenseId String
  memberId  String // ID del GroupMember
  share     Float // cuánto debe pagar

  expense Expense     @relation(fields: [expenseId], references: [id])
  member  GroupMember @relation(fields: [memberId], references: [id])

  @@unique([expenseId, memberId])
  @@map("expense_participant")
}

model CompositeExpenseItem {
  id          String   @id @default(cuid())
  expenseId   String
  description String
  amount      Float
  createdAt   DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId, createdAt(sort: Asc)])
  @@map("composite_expense_item")
}
