model Goal {
  id                 String             @id @default(cuid())
  groupId            String
  createdByMemberId  String
  title              String
  description        String?
  goalType           String             @default("saving")
  emoji              String?
  coverImageUrl      String?
  themeColor         String?
  contributionMode   String             @default("manual")
  currency           String
  targetAmount       Float
  startDate          DateTime
  endDate            DateTime
  installmentCount   Int
  installmentAmount  Float
  suggestedContributionAmount Float?
  completedAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  group         Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy     GroupMember        @relation("GoalCreatedBy", fields: [createdByMemberId], references: [id], onDelete: Restrict)
  contributions GoalContribution[]

  @@index([groupId, createdAt])
  @@map("goal")
}

model GoalContribution {
  id          String     @id @default(cuid())
  goalId      String
  memberId    String
  amount      Float
  contributedAt DateTime @default(now())
  notes       String?
  createdAt   DateTime   @default(now())

  goal   Goal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  member GroupMember @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@index([goalId, contributedAt])
  @@map("goal_contribution")
}
