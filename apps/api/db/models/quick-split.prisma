model QuickSplit {
  id          String   @id
  ownerId     String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner        User                  @relation("QuickSplitOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  participants QuickSplitParticipant[]
  expense      QuickSplitExpense?

  @@index([ownerId, createdAt(sort: Desc)])
  @@map("quick_split")
}

model QuickSplitParticipant {
  id           String     @id @default(cuid())
  quickSplitId String
  userId       String?
  name         String
  role         String     @default("participant")
  share        Float      @default(0)
  joinedAt     DateTime   @default(now())

  quickSplit   QuickSplit @relation(fields: [quickSplitId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  paidExpenses QuickSplitExpense[] @relation("QuickSplitExpensePaidByParticipant")
  settlementsFrom QuickSplitExpenseSettlement[] @relation("QuickSplitSettlementFrom")
  settlementsTo QuickSplitExpenseSettlement[] @relation("QuickSplitSettlementTo")

  @@unique([quickSplitId, userId])
  @@index([userId, joinedAt(sort: Desc)])
  @@map("quick_split_participant")
}

model QuickSplitExpense {
  id           String   @id @default(cuid())
  quickSplitId String @unique
  paidByParticipantId String
  description  String
  amount       Float
  currency     String
  splitMethod  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quickSplit   QuickSplit                  @relation(fields: [quickSplitId], references: [id], onDelete: Cascade)
  paidByParticipant QuickSplitParticipant  @relation("QuickSplitExpensePaidByParticipant", fields: [paidByParticipantId], references: [id], onDelete: Cascade)
  settlements  QuickSplitExpenseSettlement[]

  @@index([quickSplitId, createdAt(sort: Desc)])
  @@index([paidByParticipantId, createdAt(sort: Desc)])
  @@map("quick_split_expense")
}

model QuickSplitExpenseSettlement {
  id               String   @id @default(cuid())
  expenseId        String
  fromParticipantId String
  toParticipantId  String
  amount           Float
  currency         String
  createdAt        DateTime @default(now())

  expense        QuickSplitExpense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  fromParticipant QuickSplitParticipant @relation("QuickSplitSettlementFrom", fields: [fromParticipantId], references: [id], onDelete: Cascade)
  toParticipant   QuickSplitParticipant @relation("QuickSplitSettlementTo", fields: [toParticipantId], references: [id], onDelete: Cascade)

  @@index([expenseId, createdAt(sort: Desc)])
  @@index([fromParticipantId])
  @@index([toParticipantId])
  @@map("quick_split_expense_settlement")
}
