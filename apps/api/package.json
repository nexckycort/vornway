{
  "name": "@vornway/api",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "postinstall": "bun db:generate && bun build:rpc",
    "build:rpc": "tsc -p tsconfig.rpc.json",
    "dev": "portless api.vornway bun run --env-file=.env --hot src/index.ts",
    "check": "biome check --write",
    "clean": "rm -rf node_modules && rm -rf dist",
    "db:generate": "DATABASE_URL=dummy prisma generate",
    "db:migrate:create": "bun run --bun prisma migrate dev --name ",
    "db:migrate": "bun run --bun prisma migrate dev",
    "db:migrate:deploy": "bun --env-file=.env prisma migrate deploy",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "exports": {
    "./hc": {
      "import": {
        "types": "./dist/hc/index.d.ts",
        "default": "./dist/hc/index.js"
      }
    },
    "./hc/*": {
      "import": {
        "types": "./dist/hc/*.d.ts",
        "default": "./dist/hc/*.js"
      }
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@hono/mcp": "^0.2.5",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "better-auth": "catalog:",
    "hono": "catalog:",
    "resend": "catalog:",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/web-push": "^3.6.4",
    "portless": "catalog:",
    "prisma": "catalog:",
    "typescript": "catalog:"
  }
}
