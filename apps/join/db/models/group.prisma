model Group {
  id          String   @id
  name        String
  type        String
  createdAt   DateTime
  updatedAt   DateTime
  description String?
  ownerId     String
  inviteCode  String   @unique
  totals      Json     @default("{}") // Caché de totales por moneda: { "COP": 150000, "USD": 50 }
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("group")
}
