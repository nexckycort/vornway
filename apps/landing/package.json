{
  "name": "@vornway/landing",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "bunx --bun astro dev",
    "build": "bunx --bun astro build",
    "clean": "rm -rf node_modules && rm -rf dist && rm -rf .astro",
    "check": "biome check --write",
    "preview": "bunx --bun astro preview",
    "astro": "bunx --bun astro",
    "deploy": "bunx --bun astro build && bunx --bun wrangler pages deploy",
    "typecheck": "bunx --bun astro check"
  },
  "dependencies": {
    "astro": "7.1.0",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/sitemap": "3.7.3",
    "@biomejs/biome": "catalog:",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
