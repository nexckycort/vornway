---
import type { LandingContent } from "../content/landing";

export interface Props {
  content: LandingContent["assistant"];
}

const { content } = Astro.props;
---

<section class="section assistant-section">
  <div class="shell assistant-banner">
    <div class="assistant-banner-visual">
      <div class="mascot-wrap">
        <svg viewBox="0 0 200 200" class="mascot-art" aria-hidden="true">
          <ellipse cx="100" cy="85" rx="55" ry="50" fill="#de034d" />
          <ellipse cx="80" cy="75" rx="15" ry="18" fill="white" />
          <ellipse cx="120" cy="75" rx="15" ry="18" fill="white" />
          <circle cx="82" cy="78" r="8" fill="#050002" />
          <circle cx="122" cy="78" r="8" fill="#050002" />
          <circle cx="84" cy="75" r="3" fill="white" />
          <circle cx="124" cy="75" r="3" fill="white" />
          <path d="M80 100Q100 115 120 100" stroke="#050002" stroke-width="3" fill="none" stroke-linecap="round" />
          <path d="M50 120Q30 140 35 165Q40 175 50 170Q55 160 50 145Q48 135 55 125" fill="#de034d" />
          <path d="M70 130Q55 155 60 180Q65 190 75 185Q80 175 75 160Q73 145 75 135" fill="#de034d" />
          <path d="M95 135Q90 165 95 190Q100 200 110 195Q115 185 110 165Q108 150 105 140" fill="#de034d" />
          <path d="M125 130Q135 155 130 180Q130 190 120 188Q115 178 120 160Q122 145 120 135" fill="#de034d" />
          <path d="M145 120Q165 140 160 165Q155 175 145 170Q140 160 145 145Q148 135 142 125" fill="#de034d" />
          <circle cx="60" cy="95" r="8" fill="#ff6699" opacity="0.6" />
          <circle cx="140" cy="95" r="8" fill="#ff6699" opacity="0.6" />
          <ellipse cx="100" cy="40" rx="35" ry="10" fill="#1a0810" />
          <path d="M70 40L70 25Q100 10 130 25L130 40" fill="#1a0810" />
        </svg>

        <span class="mini-chip chip-left">💰</span>
        <span class="mini-chip chip-top">✈️</span>
        <span class="mini-chip chip-bottom">🗺️</span>
        <span class="mini-chip chip-right">🎯</span>
      </div>
    </div>

    <div class="section-heading assistant-copy assistant-banner-copy">
      <span class="eyebrow static">{content.badge}</span>
      <h2>
        {content.title}
        <span>{content.highlight}</span>
      </h2>
      <p>{content.description}</p>
    </div>
  </div>
</section>
