---
import type { LandingContent } from "../content/landing";
import Icon from "./Icon.astro";

export interface Props {
  content: LandingContent["comparison"];
}

const { content } = Astro.props;
---

<section class="section section-muted">
  <div class="shell narrow-shell">
    <div class="section-heading centered">
      <span class="eyebrow static">{content.badge}</span>
      <h2>
        {content.title}
        <span>{content.highlight}</span>
      </h2>
      <p>{content.description}</p>
    </div>

    <div class="comparison-table">
      <div class="comparison-row comparison-head">
        <strong>Función</strong>
        <strong>{content.brandLabel}</strong>
        <strong>Alternativas</strong>
      </div>

      {
        content.rows.map((row) => (
          <div class="comparison-row">
            <span class="comparison-feature">{row.feature}</span>
            <span class="comparison-brand">
              <span class="comparison-icon positive">
                <Icon name="check" class="icon" />
              </span>
              <span class="comparison-brand-text">Incluido</span>
            </span>
            <span class="comparison-alt">
              {
                row.alternatives === false ? (
                  <span class="comparison-alt-status">
                    <span class="comparison-icon negative">
                      <Icon name="close" class="icon" />
                    </span>
                    <span>No incluido</span>
                  </span>
                ) : (
                  row.alternatives
                )
              }
            </span>
          </div>
        ))
      }
    </div>

    <p class="comparison-summary">{content.summary}</p>
  </div>
</section>
