---
import type { LandingCopy } from "../i18n";

export interface Props {
  copy: LandingCopy;
}

const { copy } = Astro.props;
const items = copy.faq.items;
---

<section
  id="faq"
  class="relative overflow-hidden py-24 md:py-32"
  style="background: hsl(252 33% 97%)"
>
  <div class="mx-auto max-w-4xl px-6">
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <span
        class="mb-4 inline-block rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-widest"
        style="background: rgb(86 225 233 / 0.1); color: #56E1E9"
      >
        {copy.faq.badge}
      </span>
      <h2 class="font-display text-3xl font-bold tracking-tight md:text-5xl" style="color: hsl(240 38% 17%)">
        {copy.faq.title}
      </h2>
      <p class="mt-4 text-base leading-relaxed md:text-lg" style="color: hsl(240 20% 46%)">
        {copy.faq.subtitle}
      </p>
    </div>

    <div class="space-y-4">
      {
        items.map((item) => (
          <details
            class="group rounded-2xl border bg-white p-5"
            style="border-color: hsl(240 47% 47% / 0.12)"
          >
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4">
              <span
                class="font-display text-lg font-semibold leading-snug"
                style="color: hsl(240 38% 17%)"
              >
                {item.question}
              </span>
            </summary>
            <p class="mt-4 pr-8 text-sm leading-relaxed md:text-base" style="color: hsl(240 20% 46%)">
              {item.answer}
            </p>
          </details>
        ))
      }
    </div>
  </div>
</section>
