---
import type { LandingCopy } from "../i18n";

export interface Props {
  copy: LandingCopy;
}

const { copy } = Astro.props;

const icons = {
  groups: "M3 6.5h18M3 12h18M3 17.5h18",
  expenses:
    "M4 7.5h16M4 12h16M4 16.5h10M14.5 4.5v15M10 4.5v15",
  goals: "M12 4l2.6 5.3 5.9.9-4.2 4.1 1 5.7L12 17l-5.3 3 1-5.7-4.2-4.1 5.9-.9L12 4z",
  activity: "M4 12h3l2-5 4 10 2-5h5",
  participants: "M8 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm8 1a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM3 19a5 5 0 0 1 10 0m1.5 0a4.5 4.5 0 0 1 7 0",
  settle:
    "M3.5 8.5h8m0 0-2.2-2.2M11.5 8.5l-2.2 2.2M20.5 15.5h-8m0 0 2.2-2.2m-2.2 2.2 2.2 2.2",
} as const;

const slotToIcon = {
  groups: "groups",
  expenses: "expenses",
  goals: "goals",
  activity: "activity",
  participants: "participants",
  settle: "settle",
} as const;
---

<script src="../scripts/in-view.ts"></script>

<section
  id="features"
  data-feature-blocks
  data-in-view-root
  class="relative overflow-hidden py-24 md:py-32"
  style="background: hsl(240 38% 17%)"
>
  <div
    class="absolute right-0 top-0 h-96 w-96 rounded-full opacity-[0.03]"
    style="background: #56E1E9; filter: blur(100px)"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 h-96 w-96 rounded-full opacity-[0.03]"
    style="background: hsl(240 47% 47%); filter: blur(100px)"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-6xl px-6">
    <div class="feature-title mx-auto max-w-3xl text-center transition-all duration-1000">
      <span
        class="mb-4 inline-block rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-widest"
        style="background: rgb(86 225 233 / 0.1); color: #56E1E9"
      >
        {copy.featureBlocks.badge}
      </span>
      <h2 class="font-display text-3xl font-bold leading-tight tracking-tight text-white md:text-5xl">
        {copy.featureBlocks.title}
      </h2>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        copy.featureBlocks.features.map((feature, i) => {
          const iconKey = slotToIcon[feature.slot as keyof typeof slotToIcon] ?? "groups";
          const iconPath = icons[iconKey];

          return (
            <article
              class="feature-card group rounded-2xl border p-6 transition-all duration-300 hover:-translate-y-1"
              style={`border-color: hsl(240 33% 56% / 0.35); background: hsl(240 47% 47% / 0.14); transition-delay: ${i * 100}ms`}
            >
              <div class="flex items-start justify-between gap-3">
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-black/20 text-cyan-300">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path
                      d={iconPath}
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </div>
                <span
                  class="rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-wide"
                  style="background: rgb(86 225 233 / 0.18); color: #56E1E9"
                >
                  {feature.tag}
                </span>
              </div>

              <h3 class="mt-4 font-display text-xl font-bold text-white md:text-2xl">
                {feature.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed" style="color: hsl(250 25% 90% / 0.75)">
                {feature.description}
              </p>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  [data-feature-blocks] .feature-title {
    opacity: 0;
    transform: translateY(48px);
  }
  [data-feature-blocks][data-in-view="true"] .feature-title {
    opacity: 1;
    transform: translateY(0);
  }

  [data-feature-blocks] .feature-card {
    opacity: 0;
    transform: translateY(32px);
  }
  [data-feature-blocks][data-in-view="true"] .feature-card {
    opacity: 1;
    transform: translateY(0);
  }
</style>
