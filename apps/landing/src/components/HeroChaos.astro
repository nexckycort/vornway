---
import type { LandingCopy } from "../i18n";

export interface Props {
  copy: LandingCopy;
}

const { copy } = Astro.props;
const APP_LOGIN_URL = "https://me.splitway.app";

const EXPENSE_CHIPS = [
  {
    label: copy.hero.chips[0],
    color: "bg-primary text-primary-foreground",
    x: -180,
    y: -120,
    r: -12,
  },
  {
    label: copy.hero.chips[1],
    color: "bg-secondary text-secondary-foreground",
    x: 140,
    y: -80,
    r: 8,
  },
  {
    label: copy.hero.chips[2],
    color: "bg-accent text-accent-foreground",
    x: -60,
    y: 80,
    r: -6,
  },
  {
    label: copy.hero.chips[3],
    color: "bg-primary text-primary-foreground",
    x: 200,
    y: 60,
    r: 15,
  },
  {
    label: copy.hero.chips[4],
    color: "bg-secondary text-secondary-foreground",
    x: -200,
    y: 20,
    r: -18,
  },
  {
    label: copy.hero.chips[5],
    color: "bg-accent text-accent-foreground",
    x: 80,
    y: -160,
    r: 5,
  },
  {
    label: copy.hero.chips[6],
    color: "bg-primary text-primary-foreground",
    x: -120,
    y: 140,
    r: 10,
  },
  {
    label: copy.hero.chips[7],
    color: "bg-secondary text-secondary-foreground",
    x: 160,
    y: 140,
    r: -8,
  },
  {
    label: copy.hero.chips[8],
    color: "bg-muted text-muted-foreground",
    x: -30,
    y: -170,
    r: 20,
  },
  {
    label: copy.hero.chips[9],
    color: "bg-primary text-primary-foreground",
    x: 30,
    y: 170,
    r: -14,
  },
];
---

<section
  data-hero-chaos
  data-mounted="false"
  class="relative flex min-h-[100svh] flex-col items-center justify-center overflow-hidden md:min-h-screen"
  style="background: hsl(240 38% 17%)"
>
  <div
    class="geo-circle animate-spin-slow"
    style="width: 600px; height: 600px; border: 1px solid hsl(240 47% 47% / 0.15); top: 50%; left: 50%; transform: translate(-50%, -50%)"
  >
  </div>
  <div
    class="geo-circle"
    style="width: 400px; height: 400px; border: 1px solid rgb(86 225 233 / 0.1); top: 50%; left: 50%; transform: translate(-50%, -50%); animation: spin-slow 30s linear infinite reverse"
  >
  </div>
  <div
    class="geo-diamond animate-drift"
    style="width: 80px; height: 80px; background: hsl(240 47% 47% / 0.08); top: 15%; right: 12%"
  >
  </div>
  <div
    class="geo-diamond animate-float"
    style="width: 50px; height: 50px; background: rgb(86 225 233 / 0.1); bottom: 20%; left: 8%"
  >
  </div>

  <div class="relative z-10 mx-auto h-[250px] w-full max-w-3xl sm:h-[320px] md:h-[500px]">
    {
      EXPENSE_CHIPS.map((chip, i) => (
        <div
          class={`chaotic-chip absolute left-1/2 top-1/2 whitespace-nowrap rounded-full px-3 py-1.5 text-xs font-medium shadow-lg sm:px-4 sm:py-2 sm:text-sm ${chip.color}`}
          data-chip
          data-x={chip.x}
          data-y={chip.y}
          data-r={chip.r}
          style={`transition-delay:${i * 80}ms; animation-delay:${i * 160}ms;`}
        >
          <span class="relative z-10">{chip.label}</span>
        </div>
      ))
    }
  </div>

  <div class="relative z-20 mx-auto max-w-3xl px-5 text-center sm:px-6">
    <h1
      class="hero-fade font-display text-3xl font-bold leading-tight tracking-tight text-white transition-all duration-1000 sm:text-4xl md:text-6xl lg:text-7xl"
      style="--fade-delay: 800ms"
    >
      <span class="text-balance">
        {copy.hero.titleStart}
        <span class="relative inline-block text-[#56E1E9]">
          {copy.hero.titleHighlight}
          <svg
            class="hero-underline absolute -bottom-1 left-0 w-full"
            viewBox="0 0 200 12"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M2 8C40 2 100 2 198 8"
              stroke="#56E1E9"
              stroke-width="3"
              stroke-linecap="round"
              style="stroke-dasharray: 200"></path>
          </svg>
        </span>
      </span>
    </h1>
    <p
      class="hero-fade mt-4 text-base leading-relaxed text-[hsl(250_25%_90%)] transition-all duration-1000 sm:mt-6 sm:text-lg md:text-xl"
      style="--fade-delay: 1100ms"
    >
      {copy.hero.subtitle}
    </p>
    <div
      class="hero-fade mt-7 transition-all duration-1000 sm:mt-10"
      style="--fade-delay: 1400ms"
    >
      <a
        href={APP_LOGIN_URL}
        class="group relative inline-flex w-full items-center justify-center overflow-hidden rounded-full px-7 py-3 text-base font-semibold transition-all duration-300 hover:scale-105 hover:shadow-2xl sm:w-auto sm:px-8 sm:py-4 sm:text-lg"
        style="background: #56E1E9; color: hsl(240 38% 17%)"
      >
        <span class="relative z-10">{copy.hero.cta}</span>
      </a>
    </div>
  </div>

  <div
    class="hero-fade absolute bottom-6 left-1/2 hidden -translate-x-1/2 transition-all duration-1000 sm:block"
    style="--fade-delay: 1800ms"
  >
    <div class="flex flex-col items-center gap-2">
      <span
        class="text-xs uppercase tracking-widest"
        style="color: hsl(250 25% 90% / 0.5)"
      >
        {copy.hero.scrollHint}
      </span>
      <div
        class="h-10 w-6 rounded-full border-2 p-1"
        style="border-color: hsl(250 25% 90% / 0.3)"
      >
        <div
          class="mx-auto h-2 w-1.5 animate-bounce rounded-full"
          style="background: #56E1E9"
        >
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const sections = document.querySelectorAll("[data-hero-chaos]");

  sections.forEach((section) => {
    const chips = section.querySelectorAll("[data-chip]");
    let mountedTimeout;

    const applyChipTransforms = () => {
      let scale = 1;
      if (window.innerWidth < 480) {
        scale = 0.34;
      } else if (window.innerWidth < 768) {
        scale = 0.5;
      }
      chips.forEach((chip) => {
        const x = Number(chip.getAttribute("data-x") || "0") * scale;
        const y = Number(chip.getAttribute("data-y") || "0") * scale;
        const r = Number(chip.getAttribute("data-r") || "0");
        const transform = `translate(calc(-50% + ${x}px), calc(-50% + ${y}px)) rotate(${r}deg)`;
        chip.style.setProperty("--chip-transform", transform);
      });
    };

    const handleResize = () => applyChipTransforms();

    applyChipTransforms();
    mountedTimeout = window.setTimeout(() => {
      section.setAttribute("data-mounted", "true");
    }, 200);

    window.addEventListener("resize", handleResize);

    document.addEventListener("astro:beforeunload", () => {
      window.removeEventListener("resize", handleResize);
      if (mountedTimeout) {
        window.clearTimeout(mountedTimeout);
      }
    });
  });
</script>

<style>
  [data-hero-chaos] .chaotic-chip {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.8);
    transition-property: transform, opacity;
    transition-duration: 1000ms;
  }

  [data-hero-chaos][data-mounted="true"] .chaotic-chip {
    opacity: 1;
    transform: var(--chip-transform);
  }

  @media (max-width: 767px) {
    [data-hero-chaos] .geo-circle {
      opacity: 0.7;
    }

    [data-hero-chaos] .geo-diamond {
      opacity: 0.6;
    }
  }

  @media (max-width: 479px) {
    [data-hero-chaos] .chaotic-chip:nth-child(n + 8) {
      display: none;
    }
  }
</style>
