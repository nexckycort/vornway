---
const EXPENSE_CHIPS = [
  {
    label: "Taxi $48",
    color: "bg-primary text-primary-foreground",
    x: -180,
    y: -120,
    r: -12,
  },
  {
    label: "Dinner $120",
    color: "bg-secondary text-secondary-foreground",
    x: 140,
    y: -80,
    r: 8,
  },
  {
    label: "Who paid??",
    color: "bg-accent text-accent-foreground",
    x: -60,
    y: 80,
    r: -6,
  },
  {
    label: "You owe me",
    color: "bg-primary text-primary-foreground",
    x: 200,
    y: 60,
    r: 15,
  },
  {
    label: "Hotel $340",
    color: "bg-secondary text-secondary-foreground",
    x: -200,
    y: 20,
    r: -18,
  },
  {
    label: "Groceries $67",
    color: "bg-accent text-accent-foreground",
    x: 80,
    y: -160,
    r: 5,
  },
  {
    label: "Drinks $55",
    color: "bg-primary text-primary-foreground",
    x: -120,
    y: 140,
    r: 10,
  },
  {
    label: "Gas $42",
    color: "bg-secondary text-secondary-foreground",
    x: 160,
    y: 140,
    r: -8,
  },
  {
    label: "I'll pay later",
    color: "bg-muted text-muted-foreground",
    x: -30,
    y: -170,
    r: 20,
  },
  {
    label: "Museum $25",
    color: "bg-primary text-primary-foreground",
    x: 30,
    y: 170,
    r: -14,
  },
];
---

<section
  data-hero-chaos
  data-mounted="false"
  class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden"
  style="background: hsl(240 38% 17%)"
>
  <div
    class="geo-circle animate-spin-slow"
    style="width: 600px; height: 600px; border: 1px solid hsl(240 47% 47% / 0.15); top: 50%; left: 50%; transform: translate(-50%, -50%)"
  >
  </div>
  <div
    class="geo-circle"
    style="width: 400px; height: 400px; border: 1px solid hsl(174 73% 48% / 0.1); top: 50%; left: 50%; transform: translate(-50%, -50%); animation: spin-slow 30s linear infinite reverse"
  >
  </div>
  <div
    class="geo-diamond animate-drift"
    style="width: 80px; height: 80px; background: hsl(240 47% 47% / 0.08); top: 15%; right: 12%"
  >
  </div>
  <div
    class="geo-diamond animate-float"
    style="width: 50px; height: 50px; background: hsl(174 73% 48% / 0.1); bottom: 20%; left: 8%"
  >
  </div>

  <div class="relative z-10 mx-auto h-[400px] w-full max-w-3xl md:h-[500px]">
    {
      EXPENSE_CHIPS.map((chip, i) => (
        <div
          class={`chaotic-chip absolute left-1/2 top-1/2 whitespace-nowrap rounded-full px-4 py-2 text-sm font-medium shadow-lg ${chip.color}`}
          data-chip
          data-x={chip.x}
          data-y={chip.y}
          data-r={chip.r}
          style={`transition-delay:${i * 80}ms; animation-delay:${i * 160}ms;`}
        >
          <span class="relative z-10">{chip.label}</span>
        </div>
      ))
    }
  </div>

  <div class="relative z-20 mx-auto max-w-3xl px-6 text-center">
    <h1
      class="hero-fade font-display text-4xl font-bold leading-tight tracking-tight text-white transition-all duration-1000 md:text-6xl lg:text-7xl"
      style="--fade-delay: 800ms"
    >
      <span class="text-balance">
        Money between friends gets
        <span class="relative inline-block text-[hsl(174_73%_48%)]">
          messy.
          <svg
            class="hero-underline absolute -bottom-1 left-0 w-full"
            viewBox="0 0 200 12"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M2 8C40 2 100 2 198 8"
              stroke="hsl(174 73% 48%)"
              stroke-width="3"
              stroke-linecap="round"
              style="stroke-dasharray: 200"></path>
          </svg>
        </span>
      </span>
    </h1>
    <p
      class="hero-fade mt-6 text-lg leading-relaxed text-[hsl(250_25%_90%)] transition-all duration-1000 md:text-xl"
      style="--fade-delay: 1100ms"
    >
      Splitway makes it obvious.
    </p>
    <div
      class="hero-fade mt-10 transition-all duration-1000"
      style="--fade-delay: 1400ms"
    >
      <button
        type="button"
        class="group relative overflow-hidden rounded-full px-8 py-4 text-lg font-semibold transition-all duration-300 hover:scale-105 hover:shadow-2xl"
        style="background: hsl(174 73% 48%); color: hsl(240 38% 17%)"
      >
        <span class="relative z-10 flex items-center gap-2">
          Start splitting
          <svg
            width="20"
            height="20"
            viewBox="0 0 20 20"
            fill="none"
            class="transition-transform duration-300 group-hover:translate-x-1"
            aria-hidden="true"
          >
            <path
              d="M4 10h12m0 0l-4-4m4 4l-4 4"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
        <div
          class="absolute inset-0 -translate-x-full transition-transform duration-500 group-hover:translate-x-0"
          style="background: hsl(174 73% 55%)"
        >
        </div>
      </button>
    </div>
  </div>

  <div
    class="hero-fade absolute bottom-8 left-1/2 -translate-x-1/2 transition-all duration-1000"
    style="--fade-delay: 1800ms"
  >
    <div class="flex flex-col items-center gap-2">
      <span
        class="text-xs uppercase tracking-widest"
        style="color: hsl(250 25% 90% / 0.5)"
      >
        Scroll to untangle
      </span>
      <div
        class="h-10 w-6 rounded-full border-2 p-1"
        style="border-color: hsl(250 25% 90% / 0.3)"
      >
        <div
          class="mx-auto h-2 w-1.5 animate-bounce rounded-full"
          style="background: hsl(174 73% 48%)"
        >
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const sections = document.querySelectorAll("[data-hero-chaos]");

  sections.forEach((section) => {
    const chips = section.querySelectorAll("[data-chip]");
    let mountedTimeout;

    const applyChipTransforms = () => {
      const scale = window.innerWidth < 768 ? 0.5 : 1;
      chips.forEach((chip) => {
        const x = Number(chip.getAttribute("data-x") || "0") * scale;
        const y = Number(chip.getAttribute("data-y") || "0") * scale;
        const r = Number(chip.getAttribute("data-r") || "0");
        const transform = `translate(calc(-50% + ${x}px), calc(-50% + ${y}px)) rotate(${r}deg)`;
        chip.style.setProperty("--chip-transform", transform);
      });
    };

    const handleResize = () => applyChipTransforms();

    applyChipTransforms();
    mountedTimeout = window.setTimeout(() => {
      section.setAttribute("data-mounted", "true");
    }, 200);

    window.addEventListener("resize", handleResize);

    document.addEventListener("astro:beforeunload", () => {
      window.removeEventListener("resize", handleResize);
      if (mountedTimeout) {
        window.clearTimeout(mountedTimeout);
      }
    });
  });
</script>

<style>
  [data-hero-chaos] .chaotic-chip {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.8);
    transition-property: transform, opacity;
    transition-duration: 1000ms;
  }

  [data-hero-chaos][data-mounted="true"] .chaotic-chip {
    opacity: 1;
    transform: var(--chip-transform);
  }

  [data-hero-chaos] .hero-fade {
    opacity: 0;
    transform: translateY(32px);
    transition-property: opacity, transform;
    transition-duration: 1000ms;
    transition-delay: var(--fade-delay, 0ms);
  }

  [data-hero-chaos][data-mounted="true"] .hero-fade {
    opacity: 1;
    transform: translateY(0);
  }

  [data-hero-chaos] .hero-underline path {
    stroke-dashoffset: 200;
    transition: stroke-dashoffset 1000ms ease;
    transition-delay: 1400ms;
  }

  [data-hero-chaos][data-mounted="true"] .hero-underline path {
    stroke-dashoffset: 0;
  }

  .geo-circle,
  .geo-diamond {
    position: absolute;
    pointer-events: none;
  }

  @keyframes spin-slow {
    from {
      transform: translate(-50%, -50%) rotate(0deg);
    }
    to {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }

  @keyframes drift {
    0% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-12px) rotate(6deg);
    }
    100% {
      transform: translateY(0) rotate(0deg);
    }
  }

  @keyframes float {
    0% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(10px);
    }
    100% {
      transform: translateY(0);
    }
  }

  .animate-drift {
    animation: drift 18s ease-in-out infinite;
  }

  .animate-float {
    animation: float 14s ease-in-out infinite;
  }
</style>
