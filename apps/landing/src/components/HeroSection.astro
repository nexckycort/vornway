---
import type { LandingContent } from "../content/landing";
import Icon from "./Icon.astro";

export interface Props {
  content: LandingContent["hero"];
}

const { content } = Astro.props;

const modules = [
  {
    icon: "receipt",
    label: "Gastos",
    desc: "Registro y reparto",
    enabled: true,
  },
  {
    icon: "users",
    label: "Balances",
    desc: "Quién paga a quién",
    enabled: true,
  },
  { icon: "target", label: "Metas", desc: "Ahorro compartido", enabled: false },
  {
    icon: "globe",
    label: "Conversor",
    desc: "Monedas y tasas",
    enabled: false,
  },
  { icon: "map", label: "Ruta", desc: "Plan del viaje", enabled: true },
];
---

<section class="hero-section hero-section-reimagined">
  <div class="shell hero-reimagined-shell">
    <div class="hero-copy">
      <h1>
        {content.title}
        <span>{content.highlight}</span>
      </h1>

      <p>{content.description}</p>

      <div class="hero-actions">
        <a
          class="button button-primary button-large"
          href={content.primaryHref ?? "#features"}
        >
          {content.primaryCta}
        </a>
        {
          content.secondaryCta ? (
            <a
              class="button button-secondary button-large"
              href={content.secondaryHref ?? "#how-it-works"}
            >
              <Icon name="play" class="icon" />
              {content.secondaryCta}
            </a>
          ) : null
        }
      </div>

      <div class="hero-idea-row" aria-label="Concepto modular de Vornway">
        <span class="idea-chip idea-chip-on">Todo en uno flexible</span>
        <span class="idea-chip">Arma tu propia app</span>
        <span class="idea-chip idea-chip-off">Quita lo que no uses</span>
      </div>
    </div>

    <div class="hero-builder" aria-label="Vista modular de Vornway">
      <div class="hero-builder-glow" aria-hidden="true"></div>

      <div class="hero-core">
        <img
          src="/illustrations/trips.webp"
          alt="Vornway modular para viajes"
          loading="eager"
          decoding="async"
        />
        <div class="hero-core-copy">
          <strong>Núcleo Vornway</strong>
          <span>Todo en uno, pero sin ruido innecesario.</span>
        </div>
      </div>

      <div class="hero-rack" aria-label="Módulos activables">
        <div class="hero-rack-head">
          <strong>Constructor</strong>
          <span>Activa o apaga módulos</span>
        </div>
        <div class="hero-rack-grid" role="list">
          {
            modules.map((module, index) => (
              <article
                class={`hero-module module-${index + 1} ${module.enabled ? "is-on" : "is-off"}`}
                role="listitem"
              >
                <span class="hero-module-icon">
                  <Icon name={module.icon} class="icon" />
                </span>
                <div class="hero-module-copy">
                  <strong>{module.label}</strong>
                  <span>{module.desc}</span>
                </div>
                <span class="hero-module-state">
                  {module.enabled ? "ON" : "OFF"}
                </span>
              </article>
            ))
          }
        </div>
      </div>

      <div class="hero-note">
        <strong>Tú decides:</strong>
        <span>
          activa solo los módulos que necesitas hoy; si algo no te aporta, lo
          desactivas y sigues con una app más simple.
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section-reimagined {
    min-height: auto;
    padding: 7.2rem 0 3.4rem;
  }

  .hero-reimagined-shell {
    width: min(1320px, calc(100% - 1.5rem));
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(21rem, 33rem);
    gap: clamp(1.2rem, 2.6vw, 2.8rem);
    align-items: start;
  }

  .hero-copy {
    display: grid;
    gap: 1.15rem;
    max-width: 44rem;
    padding-inline: clamp(0rem, 1vw, 0.8rem);
  }

  .hero-copy h1 {
    margin: 0;
    max-width: 13ch;
    font-size: clamp(3rem, 6.5vw, 6rem);
    line-height: 0.94;
    letter-spacing: -0.072em;
    text-wrap: pretty;
  }

  .hero-copy h1 span {
    display: inline-block;
    margin-left: 0.2ch;
    background: linear-gradient(130deg, #bf0242, #ff7a68);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }

  .hero-copy p {
    margin: 0;
    max-width: 40rem;
    font-size: 1.06rem;
    line-height: 1.84;
    color: rgba(30, 30, 30, 0.68);
    text-wrap: pretty;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.72rem;
    margin-top: 0.2rem;
  }

  .hero-idea-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.2rem;
  }

  .idea-chip {
    padding: 0.34rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(75, 41, 92, 0.16);
    background: rgba(255, 255, 255, 0.62);
    color: rgba(45, 30, 55, 0.85);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .idea-chip-on {
    border-color: rgba(24, 138, 87, 0.26);
    background: rgba(216, 255, 237, 0.7);
    color: #1f6f53;
  }

  .idea-chip-off {
    border-style: dashed;
    border-color: rgba(145, 93, 172, 0.3);
    background: rgba(248, 239, 255, 0.7);
    color: #6c4685;
  }

  .hero-builder {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
    grid-template-areas:
      "core rack"
      "note note";
    gap: 0.7rem;
    padding: clamp(0.9rem, 1.5vw, 1.15rem);
    border-radius: 1.3rem;
    border: 1px solid rgba(222, 3, 77, 0.15);
    background:
      radial-gradient(
        circle at 18% 12%,
        rgba(255, 255, 255, 0.86),
        transparent 35%
      ),
      linear-gradient(
        145deg,
        rgba(255, 246, 250, 0.86),
        rgba(246, 239, 247, 0.8)
      );
    overflow: hidden;
    box-shadow:
      0 28px 54px rgba(104, 24, 74, 0.14),
      0 1px 0 rgba(255, 255, 255, 0.76) inset;
  }

  .hero-builder-glow {
    position: absolute;
    inset: 16% 14% auto;
    height: 40%;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(222, 3, 77, 0.2), transparent 72%);
    filter: blur(14px);
    pointer-events: none;
  }

  .hero-core {
    grid-area: core;
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: center;
    gap: 0.45rem;
    padding: 0.85rem 0.8rem 0.75rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.68);
    border: 1px solid rgba(255, 255, 255, 0.72);
  }

  .hero-core img {
    width: min(100%, 15.2rem);
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 16px 30px rgba(194, 44, 98, 0.22));
  }

  .hero-core-copy {
    display: grid;
    gap: 0.08rem;
    text-align: center;
  }

  .hero-core-copy strong {
    font-size: 0.9rem;
    line-height: 1.25;
  }

  .hero-core-copy span {
    font-size: 0.78rem;
    line-height: 1.35;
    color: rgba(30, 30, 30, 0.65);
  }

  .hero-rack {
    grid-area: rack;
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.5rem;
    align-content: start;
    padding: 0.55rem;
    border-radius: 0.95rem;
    border: 1px solid rgba(222, 3, 77, 0.12);
    background: rgba(255, 255, 255, 0.56);
  }

  .hero-rack-head {
    display: grid;
    gap: 0.03rem;
    padding: 0 0.12rem 0.18rem;
  }

  .hero-rack-head strong {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .hero-rack-head span {
    font-size: 0.72rem;
    color: rgba(30, 30, 30, 0.62);
  }

  .hero-rack-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.45rem;
  }

  .hero-module {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 0.65rem;
    border-radius: 0.86rem;
    border: 1px solid rgba(222, 3, 77, 0.13);
    background: rgba(255, 255, 255, 0.74);
  }

  .hero-module-icon {
    display: inline-grid;
    place-items: center;
    width: 1.95rem;
    height: 1.95rem;
    border-radius: 0.7rem;
    color: #7f2953;
    background: rgba(222, 3, 77, 0.12);
  }

  .hero-module-copy {
    display: grid;
    gap: 0.02rem;
  }

  .hero-module-copy strong {
    font-size: 0.86rem;
    line-height: 1.2;
  }

  .hero-module-copy span {
    font-size: 0.72rem;
    line-height: 1.24;
    color: rgba(30, 30, 30, 0.58);
  }

  .hero-module-state {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.6rem;
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .hero-module.is-on .hero-module-state {
    color: #186f4c;
    background: rgba(208, 250, 228, 0.88);
    border: 1px solid rgba(24, 138, 87, 0.24);
  }

  .hero-module.is-off {
    border-style: dashed;
    border-color: rgba(75, 41, 92, 0.22);
    background: rgba(248, 241, 255, 0.7);
  }

  .hero-module.is-off .hero-module-state {
    color: #775191;
    background: rgba(238, 222, 255, 0.76);
    border: 1px solid rgba(119, 81, 145, 0.24);
  }

  .hero-note {
    grid-area: note;
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.06rem;
    padding: 0.7rem 0.78rem;
    border-radius: 0.88rem;
    border: 1px solid rgba(222, 3, 77, 0.16);
    background: rgba(255, 238, 245, 0.78);
    box-shadow: 0 10px 22px rgba(161, 36, 91, 0.12);
  }

  .hero-note strong {
    font-size: 0.76rem;
    line-height: 1.3;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-note span {
    font-size: 0.78rem;
    line-height: 1.38;
    color: rgba(30, 30, 30, 0.7);
  }

  @media (max-width: 1080px) {
    .hero-section-reimagined {
      padding: 6.8rem 0 3rem;
    }

    .hero-reimagined-shell {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .hero-copy {
      max-width: none;
    }

    .hero-copy h1 {
      max-width: 12ch;
      font-size: clamp(2.8rem, 10vw, 4.8rem);
    }

    .hero-builder {
      max-width: 42rem;
      width: 100%;
    }
  }

  @media (max-width: 820px) {
    .hero-section-reimagined {
      padding: 6.3rem 0 2.8rem;
    }

    .hero-reimagined-shell {
      width: min(100%, calc(100% - 1.2rem));
    }

    .hero-copy p {
      font-size: 0.99rem;
      line-height: 1.72;
    }

    .hero-core img {
      width: min(100%, 12rem);
    }

    .hero-builder {
      grid-template-columns: 1fr;
      grid-template-areas:
        "core"
        "rack"
        "note";
    }

    .hero-rack-grid {
      grid-template-columns: 1fr;
    }
  }

  :root.dark .hero-copy h1 {
    color: #f6f8fc;
  }

  :root.dark .hero-copy p {
    color: rgba(230, 235, 244, 0.78);
  }

  :root.dark .idea-chip {
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(235, 240, 248, 0.84);
  }

  :root.dark .idea-chip-on {
    background: rgba(57, 183, 122, 0.2);
    border-color: rgba(57, 183, 122, 0.34);
    color: #8ae9be;
  }

  :root.dark .idea-chip-off {
    background: rgba(146, 95, 171, 0.18);
    border-color: rgba(180, 126, 209, 0.32);
    color: #dfbcf9;
  }

  :root.dark .hero-builder {
    border-color: rgba(255, 120, 160, 0.22);
    background:
      radial-gradient(
        circle at 18% 12%,
        rgba(255, 255, 255, 0.04),
        transparent 35%
      ),
      linear-gradient(145deg, rgba(27, 11, 19, 0.88), rgba(20, 10, 16, 0.84));
  }

  :root.dark .hero-rack {
    border-color: rgba(255, 120, 160, 0.18);
    background: rgba(255, 255, 255, 0.03);
  }

  :root.dark .hero-rack-head span {
    color: rgba(230, 235, 244, 0.72);
  }

  :root.dark .hero-core,
  :root.dark .hero-module {
    border-color: rgba(255, 255, 255, 0.11);
    background: rgba(255, 255, 255, 0.04);
  }

  :root.dark .hero-core-copy span,
  :root.dark .hero-module-copy span,
  :root.dark .hero-note span {
    color: rgba(230, 235, 244, 0.75);
  }

  :root.dark .hero-module-icon {
    background: rgba(255, 120, 160, 0.2);
    color: #ffc0dc;
  }

  :root.dark .hero-note {
    border-color: rgba(255, 120, 160, 0.22);
    background: rgba(255, 120, 160, 0.08);
  }

  :root.dark .hero-module.is-off {
    border-color: rgba(180, 126, 209, 0.3);
    background: rgba(146, 95, 171, 0.12);
  }

  :root.dark .hero-module.is-off .hero-module-state {
    color: #dfbcf9;
    border-color: rgba(180, 126, 209, 0.34);
    background: rgba(146, 95, 171, 0.22);
  }
</style>
