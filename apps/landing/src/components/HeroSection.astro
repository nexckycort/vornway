---
import type { LandingContent } from "../content/landing";
import Icon from "./Icon.astro";

export interface Props {
  content: LandingContent["hero"];
}

const { content } = Astro.props;
---

<section class="hero-section">
  <div class="hero-bg hero-bg-left"></div>
  <div class="hero-bg hero-bg-right"></div>

  <div class="shell hero-grid">
    <div class="hero-copy">
      <h1>
        {content.title}
        <span>{content.highlight}</span>
      </h1>

      <p>{content.description}</p>

      <div class="hero-actions">
        <a class="button button-primary button-large" href={content.primaryHref ?? "#cta"}>
          {content.primaryCta}
          <Icon name="arrow-right" class="icon" />
        </a>
        <a class="button button-secondary button-large" href={content.secondaryHref ?? "#how-it-works"} target={content.secondaryHref ? "_blank" : undefined} rel={content.secondaryHref ? "noreferrer" : undefined}>
          <Icon name="play" class="icon" />
          {content.secondaryCta}
        </a>
      </div>

      <div class="hero-stats">
        {
          content.stats.map((stat) => (
            <div class="hero-stat">
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="hero-visual">
      <div class="phone-frame">
        <div class="phone-notch"></div>

        <div class="phone-content">
          <div class="phone-header">
            <div>
              <p>{content.welcomeLabel}</p>
              <strong>{content.welcomeName}</strong>
            </div>
            <span class="avatar">C</span>
          </div>

          <div class="balance-card">
            <p>{content.balanceLabel}</p>
            <strong>{content.balanceValue}</strong>
            <div class="balance-meta">
              <div class="avatar-stack">
                <span>A</span>
                <span>B</span>
                <span>C</span>
                <span>D</span>
              </div>
              <span>{content.balanceMeta}</span>
            </div>
          </div>

          <div class="expense-list">
            <p>{content.recentLabel ?? "Gastos recientes"}</p>
            {
              content.recentExpenses.map((expense) => (
                <article class="expense-item">
                  <div>
                    <span class="expense-icon">{expense.icon}</span>
                    <strong>{expense.name}</strong>
                  </div>
                  <span>{expense.amount}</span>
                </article>
              ))
            }
          </div>
        </div>
      </div>

      <div class="floating-card floating-card-left">
        <span class="floating-icon floating-icon-success">{content.floatingCards[0]?.icon}</span>
        <div>
          <strong>{content.floatingCards[0]?.title}</strong>
          <span>{content.floatingCards[0]?.subtitle}</span>
        </div>
      </div>

      <div class="floating-card floating-card-right">
        <span class="floating-icon floating-icon-accent">{content.floatingCards[1]?.icon}</span>
        <div>
          <strong>{content.floatingCards[1]?.title}</strong>
          <span>{content.floatingCards[1]?.subtitle}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-scroll">
    <span>{content.scrollHint}</span>
    <div class="scroll-pill">
      <i></i>
    </div>
  </div>
</section>
