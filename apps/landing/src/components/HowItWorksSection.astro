---
import type { LandingContent } from "../content/landing";
import Icon from "./Icon.astro";

export interface Props {
  content: LandingContent["howItWorks"];
}

const { content } = Astro.props;
---

<section id={content.id} class="section">
  <div class="shell">
    <div class="section-heading centered">
      <h2>
        {content.title}
        <span>{content.highlight}</span>
      </h2>
      <p>{content.description}</p>
    </div>

    <div class="steps-grid steps-showcase">
      {
        content.steps.map((step, index) => (
          <article class="surface-card step-card">
            <div class="step-visual">
              <span class:list={["icon-badge", "large", "step-icon-badge", `step-icon-${index + 1}`]}>
                <Icon name={step.icon} class="icon" />
              </span>
              <strong class="step-number-display">{String(index + 1).padStart(2, "0")}</strong>
            </div>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
