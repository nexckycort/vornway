---
import type { LandingContent } from "../content/landing";
import BrandMark from "./BrandMark.astro";
import Icon from "./Icon.astro";

export interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
---

<header class="site-nav">
  <div class="shell nav-shell">
    <a class="brand-link" href="/" aria-label={content.brand.name}>
      <span class="brand-badge">
        <BrandMark class="brand-mark" />
      </span>
      <span class="brand-copy">
        <strong>{content.brand.name}</strong>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Principal">
      {
        content.navbar.links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))
      }
    </nav>

    <div class="desktop-actions">
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Cambiar tema">
        <span class="theme-icon theme-icon-sun"><Icon name="sun" class="icon" /></span>
        <span class="theme-icon theme-icon-moon"><Icon name="moon" class="icon" /></span>
      </button>
      <a class="button button-ghost" href={content.manifesto.figmaHref} target="_blank" rel="noreferrer">{content.navbar.loginLabel}</a>
      <a class="button button-primary" href="#manifesto">{content.navbar.primaryCta}</a>
    </div>

    <button class="mobile-toggle" type="button" data-nav-toggle aria-expanded="false" aria-label={content.navbar.menuLabel}>
      <Icon name="menu" class="icon" />
    </button>
  </div>

  <div class="mobile-panel" data-nav-panel hidden>
    <div class="shell mobile-panel-inner">
      {
        content.navbar.links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))
      }
      <button class="theme-toggle mobile-theme-toggle" type="button" data-theme-toggle aria-label="Cambiar tema">
        <span class="theme-icon theme-icon-sun"><Icon name="sun" class="icon" /></span>
        <span class="theme-label">Cambiar tema</span>
        <span class="theme-icon theme-icon-moon"><Icon name="moon" class="icon" /></span>
      </button>
      <a class="button button-ghost" href={content.manifesto.figmaHref} target="_blank" rel="noreferrer">{content.navbar.loginLabel}</a>
      <a class="button button-primary" href="#manifesto">{content.navbar.primaryCta}</a>
    </div>
  </div>
</header>

<script is:inline>
  const toggle = document.querySelector("[data-nav-toggle]");
  const panel = document.querySelector("[data-nav-panel]");
  const themeButtons = document.querySelectorAll("[data-theme-toggle]");
  const root = document.documentElement;
  const storageKey = "vornway-theme";

  const syncTheme = (theme) => {
    root.classList.toggle("dark", theme === "dark");
    root.dataset.theme = theme;
    localStorage.setItem(storageKey, theme);
  };

  themeButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const current = root.classList.contains("dark") ? "dark" : "light";
      syncTheme(current === "dark" ? "light" : "dark");
    });
  });

  if (toggle instanceof HTMLButtonElement && panel instanceof HTMLElement) {
    const close = () => {
      toggle.setAttribute("aria-expanded", "false");
      panel.hidden = true;
    };

    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      panel.hidden = expanded;
    });

    panel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", close);
    });
  }
</script>
