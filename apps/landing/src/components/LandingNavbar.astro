---
import type { LandingContent } from "../content/landing";
import BrandMark from "./BrandMark.astro";
import Icon from "./Icon.astro";

export interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
---

<header class="site-nav" id="top">
  <div class="shell nav-shell">
    <a class="brand-link" href="#top" aria-label={content.brand.name}>
      <span class="brand-badge">
        <BrandMark class="brand-mark" />
      </span>
      <span class="brand-copy">
        <strong>{content.brand.name}</strong>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Principal">
      {
        content.navbar.links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))
      }
    </nav>

    <div class="desktop-actions">
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Cambiar tema" aria-pressed="false">
        <span class="theme-icon theme-icon-sun">
          <Icon name="sun" class="icon" />
        </span>
        <span class="theme-icon theme-icon-moon">
          <Icon name="moon" class="icon" />
        </span>
      </button>
      <a class="button button-primary" href="#manifesto">{content.navbar.primaryCta}</a>
    </div>

    <button class="mobile-toggle" type="button" data-nav-toggle aria-expanded="false" aria-label={content.navbar.menuLabel}>
      <Icon name="menu" class="icon" />
    </button>
  </div>

  <div class="mobile-panel" data-nav-panel hidden>
    <div class="shell mobile-panel-inner">
      <button class="button button-ghost theme-toggle mobile-theme-toggle" type="button" data-theme-toggle aria-label="Cambiar tema" aria-pressed="false">
        <span>Cambiar tema</span>
        <span class="theme-icon theme-icon-sun">
          <Icon name="sun" class="icon" />
        </span>
        <span class="theme-icon theme-icon-moon">
          <Icon name="moon" class="icon" />
        </span>
      </button>
      {
        content.navbar.links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))
      }
      <a class="button button-primary mobile-cta" href="#manifesto">{content.navbar.primaryCta}</a>
    </div>
  </div>
</header>

<script is:inline>
  const toggle = document.querySelector("[data-nav-toggle]");
  const panel = document.querySelector("[data-nav-panel]");
  const themeToggles = Array.from(document.querySelectorAll("[data-theme-toggle]"));

  const syncThemeToggleState = () => {
    const isDark = document.documentElement.dataset.theme === "dark";

    themeToggles.forEach((themeToggle) => {
      if (themeToggle instanceof HTMLButtonElement) {
        themeToggle.setAttribute("aria-pressed", String(isDark));
        themeToggle.setAttribute("aria-label", isDark ? "Cambiar a modo claro" : "Cambiar a modo oscuro");
      }
    });
  };

  const themeApi = window.__vornwayTheme;

  if (themeApi && themeToggles.length > 0) {
    syncThemeToggleState();

    themeToggles.forEach((themeToggle) => {
      if (themeToggle instanceof HTMLButtonElement) {
        themeToggle.addEventListener("click", () => {
          themeApi.toggle();
          syncThemeToggleState();
        });
      }
    });
  }

  if (toggle instanceof HTMLButtonElement && panel instanceof HTMLElement) {
    const close = () => {
      toggle.setAttribute("aria-expanded", "false");
      panel.hidden = true;
    };

    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      panel.hidden = expanded;
    });

    panel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", close);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 820) {
        close();
      }
    });
  }
</script>
