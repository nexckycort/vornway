---
import type { LandingContent } from "../content/landing";
import BrandMark from "./BrandMark.astro";
import Icon from "./Icon.astro";

export interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
---

<header class="site-nav" id="top">
  <div class="shell nav-shell">
    <a class="brand-link" href="#top" aria-label={content.brand.name}>
      <span class="brand-badge">
        <BrandMark class="brand-mark" />
      </span>
      <span class="brand-copy">
        <strong>{content.brand.name}</strong>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Principal">
      {
        content.navbar.links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))
      }
    </nav>

    <div class="desktop-actions">
      <a class="button button-primary" href="#features">{content.navbar.primaryCta}</a>
    </div>

    <button class="mobile-toggle" type="button" data-nav-toggle aria-expanded="false" aria-label={content.navbar.menuLabel}>
      <Icon name="menu" class="icon" />
    </button>
  </div>

  <div class="mobile-panel" data-nav-panel hidden>
    <div class="shell mobile-panel-inner">
      {
        content.navbar.links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))
      }
      <a class="button button-primary mobile-cta" href="#features">{content.navbar.primaryCta}</a>
    </div>
  </div>
</header>

<script is:inline>
  const toggle = document.querySelector("[data-nav-toggle]");
  const panel = document.querySelector("[data-nav-panel]");

  if (toggle instanceof HTMLButtonElement && panel instanceof HTMLElement) {
    const close = () => {
      toggle.setAttribute("aria-expanded", "false");
      panel.hidden = true;
    };

    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      panel.hidden = expanded;
    });

    panel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", close);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 820) {
        close();
      }
    });
  }
</script>
