---
---

<main class="vw-page">
  <section class="vw-hero">
    <div class="shell vw-shell">
      <p class="vw-badge">Built for travelers</p>
      <h1>Group travel, done right.</h1>
      <p class="vw-lead">
        Shared expenses, balances, routes, and coordination in one calm product.
      </p>

      <div class="vw-visual">
        <div class="vw-visual-frame">
          <img
            src="/illustrations/trips.webp"
            alt="Travel companion mascot"
            loading="eager"
          />
        </div>
      </div>

      <a class="vw-button" href="https://app.vornway.com">
        Open app
      </a>
    </div>
  </section>
</main>

<style>
  .vw-page {
    min-height: 100vh;
    background: #0f0f10;
    color: #f5f5f5;
  }

  .vw-hero {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem 0;
  }

  .vw-shell {
    width: min(760px, calc(100% - 2rem));
    display: grid;
    justify-items: center;
    gap: 1rem;
    text-align: center;
  }

  .vw-badge {
    margin: 0;
    width: fit-content;
    padding: 0.45rem 0.7rem;
    border: 1px solid rgba(245, 245, 245, 0.08);
    border-radius: 999px;
    color: rgba(245, 245, 245, 0.68);
    font-size: 0.76rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .vw-shell h1 {
    margin: 0;
    max-width: 10ch;
    font-size: clamp(3.8rem, 10vw, 7rem);
    line-height: 0.92;
    letter-spacing: -0.085em;
    text-wrap: balance;
  }

  .vw-lead {
    max-width: 34rem;
    margin: 0;
    color: rgba(245, 245, 245, 0.68);
    font-size: clamp(1.02rem, 1.6vw, 1.15rem);
    line-height: 1.8;
    text-wrap: pretty;
  }

  .vw-visual {
    width: min(100%, 38rem);
    display: grid;
    justify-items: center;
    gap: 0.85rem;
    margin: 0.75rem 0 0.25rem;
  }

  .vw-visual-frame {
    width: min(100%, 26rem);
  }

  .vw-visual-frame img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .vw-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0.82rem 1.15rem;
    border-radius: 999px;
    border: 1px solid transparent;
    font-weight: 700;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
    background: #de034d;
    color: #fff;
    text-decoration: none;
  }

  .vw-button:hover {
    transform: translateY(-1px);
  }

</style>
