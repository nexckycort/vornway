---
import type { LandingContent } from "../content/landing";
import AILayerSection from "./AILayerSection.astro";
import AssistantSection from "./AssistantSection.astro";
import ComparisonSection from "./ComparisonSection.astro";
import FeaturesSection from "./FeaturesSection.astro";
import HeroSection from "./HeroSection.astro";
import HowItWorksSection from "./HowItWorksSection.astro";
import LandingFooter from "./LandingFooter.astro";
import LandingNavbar from "./LandingNavbar.astro";
import PreFooterBanner from "./PreFooterBanner.astro";
import WaitlistSection from "./WaitlistSection.astro";

export interface Props {
  content: LandingContent;
}

const { content } = Astro.props;
---

<div class="page-shell">
  <div class="noise-overlay" aria-hidden="true"></div>
  <LandingNavbar content={content} />

  <main>
    <HeroSection content={content.hero} />
    <!-- <ProblemSection content={content.problem} /> -->
    <FeaturesSection content={content.features} />
    <HowItWorksSection content={content.howItWorks} />
    <AssistantSection content={content.assistant} />
    <AILayerSection content={content.aiLayer} />
    <!-- <ManifestoSection content={content.manifesto} /> -->
    <ComparisonSection content={content.comparison} />
    <PreFooterBanner content={content.preFooterBanner} />
    <WaitlistSection content={content.waitlist} />
  </main>

  <LandingFooter content={content} />
</div>
