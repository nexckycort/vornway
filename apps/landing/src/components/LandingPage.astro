---
---

<main class="vw-page">
  <section class="vw-hero">
    <div class="shell vw-shell">
      <p class="vw-badge">Vornway is live</p>
      <h1>Split travel expenses without friction.</h1>
      <p class="vw-lead">
        Create groups, add expenses, track balances, and coordinate every trip
        in one app.
      </p>

      <div class="vw-visual">
        <div class="vw-visual-frame">
          <img
            src="/illustrations/trips.webp"
            alt="Vornway app preview"
            loading="eager"
          />
        </div>
      </div>

      <div class="vw-actions">
        <a class="vw-button" href="https://app.vornway.com">Open app</a>
        <p class="vw-helper">Web app + PWA for iOS and Android</p>
      </div>

      <div class="vw-features" aria-label="Main features">
        <p>Shared expenses</p>
        <p>Real-time balances</p>
        <p>Invite by QR or link</p>
      </div>
    </div>
  </section>
</main>

<style>
  .vw-page {
    min-height: 100vh;
    background:
      radial-gradient(
        60rem 30rem at 50% -10rem,
        rgba(222, 3, 77, 0.12),
        transparent 70%
      ),
      #0f0f10;
    color: #f5f5f5;
  }

  .vw-hero {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem 0;
  }

  .vw-shell {
    width: min(760px, calc(100% - 2rem));
    display: grid;
    justify-items: center;
    gap: 1.1rem;
    text-align: center;
  }

  .vw-badge {
    margin: 0;
    width: fit-content;
    padding: 0.45rem 0.7rem;
    border: 1px solid rgba(245, 245, 245, 0.08);
    border-radius: 999px;
    color: rgba(245, 245, 245, 0.68);
    font-size: 0.76rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .vw-shell h1 {
    margin: 0;
    max-width: 13ch;
    font-size: clamp(2.5rem, 7.5vw, 5.25rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .vw-lead {
    max-width: 38rem;
    margin: 0;
    color: rgba(245, 245, 245, 0.68);
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    line-height: 1.65;
    text-wrap: pretty;
  }

  .vw-visual {
    width: min(100%, 38rem);
    display: grid;
    justify-items: center;
    gap: 0.85rem;
    margin: 0.75rem 0 0.25rem;
  }

  .vw-visual-frame {
    width: min(100%, 26rem);
  }

  .vw-visual-frame img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .vw-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0.82rem 1.15rem;
    border-radius: 999px;
    border: 1px solid transparent;
    font-weight: 700;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
    background: #de034d;
    color: #fff;
    text-decoration: none;
    box-shadow: 0 10px 28px rgba(222, 3, 77, 0.28);
  }

  .vw-button:hover {
    transform: translateY(-1px);
  }

  .vw-actions {
    display: grid;
    gap: 0.65rem;
    justify-items: center;
  }

  .vw-helper {
    margin: 0;
    color: rgba(245, 245, 245, 0.55);
    font-size: 0.86rem;
  }

  .vw-features {
    margin-top: 0.5rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.55rem;
  }

  .vw-features p {
    margin: 0;
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(245, 245, 245, 0.1);
    color: rgba(245, 245, 245, 0.72);
    font-size: 0.82rem;
    letter-spacing: 0.01em;
    background: rgba(255, 255, 255, 0.02);
  }

  @media (max-width: 640px) {
    .vw-hero {
      padding: 1.25rem 0;
    }

    .vw-shell {
      gap: 1rem;
    }
  }

</style>
