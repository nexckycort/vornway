---
import type { LandingCopy } from "../i18n";

export interface Props {
  copy: LandingCopy;
}

const { copy } = Astro.props;
const APP_URL = "https://me.splitway.app";

function resolveLink(label: string): string {
  const key = label.toLocaleLowerCase("en");

  if (key.includes("privacy") || key.includes("privacidad")) {
    return "https://splitway.app/privacy";
  }

  if (key.includes("terms") || key.includes("terminos")) {
    return "https://splitway.app/terms";
  }

  return APP_URL;
}
---

<footer
  class="relative overflow-hidden py-16"
  style="background: hsl(240 38% 14%); border-top: 1px solid hsl(240 47% 47% / 0.1)"
>
  <div class="mx-auto max-w-6xl px-6">
    <div
      class="flex flex-col gap-12 md:flex-row md:items-start md:justify-between"
    >
      <div class="max-w-xs">
        <div class="flex items-center gap-2">
          <div
            class="flex h-8 w-8 items-center justify-center rounded-lg"
            style="background: hsl(174 73% 48%)"
          >
            <img src="/logo.svg" alt="logo" />
          </div>
          <span class="font-display text-lg font-bold" style="color: white"
            >Splitway</span
          >
        </div>
        <p
          class="mt-3 text-sm leading-relaxed"
          style="color: hsl(250 25% 90% / 0.5)"
        >
          {copy.footer.tagline}
        </p>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-center justify-between gap-4 border-t pt-8 sm:flex-row"
      style="border-color: hsl(240 47% 47% / 0.08)"
    >
      <p class="text-xs" style="color: hsl(250 25% 90% / 0.3)">
        {copy.footer.rights}
      </p>
      <div class="flex gap-4">
        {
          copy.footer.links.map((link) => (
            <a
              href={resolveLink(link)}
              class="text-xs transition-colors duration-200 hover:opacity-100"
              style="color: hsl(250 25% 90% / 0.4)"
            >
              {link}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
