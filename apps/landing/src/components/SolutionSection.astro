---
import type { LandingContent } from "../content/landing";

export interface Props {
  content: LandingContent["solution"];
}

const { content } = Astro.props;
---

<section class="section">
  <div class="shell split-grid">
    <div class="dashboard-shell">
      <div class="surface-card dashboard-card">
        <div class="dashboard-header">
          <div class="dashboard-brand">
            <span class="dashboard-logo">S</span>
            <div>
              <strong>{content.tripName}</strong>
              <p>{content.participants}</p>
            </div>
          </div>
          <div class="dashboard-lights">
            <i></i>
            <i></i>
            <i></i>
          </div>
        </div>

        <div class="dashboard-stats">
          {
            content.stats.map((stat) => (
              <article>
                <span>{stat.label}</span>
                <strong>{stat.value}</strong>
              </article>
            ))
          }
        </div>

        <div class="balances-panel">
          <p>{content.balancesTitle}</p>
          <div class="balance-list">
            {
              content.balances.map((person) => (
                <article>
                  <div class="balance-person">
                    <span>{person.name[0]}</span>
                    <strong>{person.name}</strong>
                  </div>
                  <span class:list={["balance-value", person.positive ? "positive" : "negative"]}>
                    {person.balance}
                  </span>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div class="section-heading">
      <span class="eyebrow static">{content.badge}</span>
      <h2>
        {content.title}
        <span>{content.highlight}</span>
      </h2>
      <p>{content.description}</p>

      <div class="benefit-grid">
        {
          content.benefits.map((benefit) => (
            <div class="benefit-item">
              <span>✓</span>
              <strong>{benefit.label}</strong>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
