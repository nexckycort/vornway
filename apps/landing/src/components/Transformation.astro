---
import type { LandingCopy } from "../i18n";

export interface Props {
  copy: LandingCopy;
}

const { copy } = Astro.props;
const showcase = copy.transformation.showcase;
---

<script src="../scripts/in-view.ts"></script>

<section
  id="how-it-works"
  data-in-view-root
  data-showcase
  class="relative overflow-hidden py-24 md:py-32"
  style="background: hsl(252 33% 97%)"
>
  <div
    class="absolute -left-24 top-10 h-72 w-72 rounded-full blur-3xl"
    style="background: rgb(86 225 233 / 0.14)"
  >
  </div>
  <div
    class="absolute -right-20 bottom-0 h-80 w-80 rounded-full blur-3xl"
    style="background: hsl(240 47% 47% / 0.2)"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6">
    <div class="intro mx-auto mb-14 max-w-3xl text-center">
      <span
        class="mb-4 inline-block rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-widest"
        style="background: rgb(86 225 233 / 0.12); color: #56E1E9"
      >
        {copy.transformation.badge}
      </span>
      <h2
        class="font-display text-3xl font-bold leading-tight tracking-tight md:text-6xl"
        style="color: hsl(240 38% 17%)"
      >
        <span class="text-balance">{showcase.title}</span>
      </h2>
      <p
        class="mx-auto mt-4 max-w-2xl text-base leading-relaxed md:text-lg"
        style="color: hsl(240 20% 46%)"
      >
        {showcase.description}
      </p>
    </div>

    <div
      class="showcase-grid grid gap-8 lg:grid-cols-[1fr_1.15fr_1fr] lg:items-end"
    >
      <article class="phone-wrap phone-left">
        <div class="float-tag float-a">{showcase.tagExpenseQuick}</div>
        <div class="phone-frame">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <div class="app-head">{showcase.screenGroupTitle}</div>
            <div class="placeholder-lines">
              <span></span><span></span><span></span>
            </div>
            <div class="card-list">
              {
                showcase.placeholderExpenses.map((item) => (
                  <div class="card-item"><b>{item.label}</b><small>{item.amount}</small></div>
                ))
              }
            </div>
          </div>
        </div>
      </article>

      <article class="phone-wrap phone-center">
        <div class="float-tag float-b">{showcase.tagLiveUpdates}</div>
        <div class="float-tag float-c">{showcase.tagSyncBalances}</div>
        <div class="phone-frame">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <div class="app-head">{showcase.screenActivityTitle}</div>
            <div class="timeline">
              {
                showcase.placeholderActivity.map((item) => (
                  <div><b>{item.title}</b><small>{item.subtitle}</small></div>
                ))
              }
            </div>
            <div class="live-pill">{showcase.liveLabel}</div>
          </div>
        </div>
      </article>

      <article class="phone-wrap phone-right">
        <div class="float-tag float-d">{showcase.tagSettleSuggestions}</div>
        <div class="phone-frame">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <div class="app-head">{showcase.screenSettleTitle}</div>
            <div class="settle-grid">
              {
                showcase.placeholderSettle.map((item) => (
                  <div><b>{item.name}</b><small>{item.amount}</small></div>
                ))
              }
            </div>
            <button class="cta-placeholder">{showcase.settleNow}</button>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .showcase-grid {
    perspective: 1200px;
  }

  .phone-wrap {
    position: relative;
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 850ms ease,
      transform 850ms ease;
  }

  .phone-left {
    transition-delay: 120ms;
  }

  .phone-center {
    transition-delay: 260ms;
  }

  .phone-right {
    transition-delay: 400ms;
  }

  .phone-frame {
    position: relative;
    margin: 0 auto;
    width: min(100%, 320px);
    border-radius: 34px;
    padding: 10px;
    background: linear-gradient(
      170deg,
      hsl(240 47% 47% / 0.75),
      rgb(86 225 233 / 0.75)
    );
    box-shadow: 0 30px 80px hsl(240 38% 3% / 0.45);
  }

  .phone-center .phone-frame {
    width: min(100%, 360px);
    transform: translateY(-10px) scale(1.04);
  }

  .phone-screen {
    position: relative;
    min-height: 520px;
    border-radius: 26px;
    padding: 20px 16px;
    background: linear-gradient(180deg, hsl(240 38% 13%), hsl(240 38% 9%));
    border: 1px solid hsl(250 25% 90% / 0.08);
    color: hsl(250 25% 95%);
  }

  .phone-notch {
    position: absolute;
    left: 50%;
    top: 8px;
    width: 34%;
    height: 20px;
    border-radius: 999px;
    background: hsl(240 38% 6%);
    transform: translateX(-50%);
    z-index: 5;
  }

  .app-head {
    margin-top: 16px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #56e1e9;
  }

  .placeholder-lines {
    margin-top: 12px;
    display: grid;
    gap: 8px;
  }

  .placeholder-lines span {
    display: block;
    height: 8px;
    border-radius: 999px;
    background: hsl(250 25% 90% / 0.12);
  }

  .placeholder-lines span:nth-child(1) {
    width: 82%;
  }

  .placeholder-lines span:nth-child(2) {
    width: 66%;
  }

  .placeholder-lines span:nth-child(3) {
    width: 74%;
  }

  .card-list,
  .timeline,
  .settle-grid {
    margin-top: 16px;
    display: grid;
    gap: 10px;
  }

  .card-item,
  .timeline div,
  .settle-grid div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-radius: 12px;
    padding: 12px;
    background: hsl(240 38% 17%);
    border: 1px solid hsl(250 25% 90% / 0.08);
  }

  .card-item b,
  .timeline b,
  .settle-grid b {
    font-size: 13px;
    color: white;
  }

  .card-item small,
  .timeline small,
  .settle-grid small {
    font-size: 12px;
    color: hsl(250 25% 90% / 0.65);
  }

  .live-pill {
    margin-top: 14px;
    display: inline-flex;
    border-radius: 999px;
    padding: 6px 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: hsl(240 38% 10%);
    background: #56e1e9;
  }

  .cta-placeholder {
    margin-top: 14px;
    width: 100%;
    border: 0;
    border-radius: 12px;
    padding: 11px 12px;
    background: #56e1e9;
    color: hsl(240 38% 10%);
    font-size: 13px;
    font-weight: 700;
  }

  .float-tag {
    position: absolute;
    z-index: 8;
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: hsl(240 38% 10%);
    background: #56e1e9;
    box-shadow: 0 12px 24px rgb(86 225 233 / 0.3);
    animation: floatTag 4s ease-in-out infinite;
  }

  .float-a {
    right: -8px;
    top: 40px;
  }

  .float-b {
    left: -20px;
    top: 64px;
    animation-delay: 0.8s;
  }

  .float-c {
    right: -22px;
    bottom: 86px;
    animation-delay: 1.5s;
  }

  .float-d {
    left: -14px;
    top: 48px;
    animation-delay: 2.2s;
  }

  @keyframes floatTag {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  [data-showcase] .intro {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 700ms ease,
      transform 700ms ease;
  }

  [data-showcase][data-in-view="true"] .intro,
  [data-showcase][data-in-view="true"] .phone-wrap {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1023px) {
    .showcase-grid {
      display: flex;
      gap: 16px;
      overflow-x: auto;
      padding: 2px 4px 10px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }

    .showcase-grid::-webkit-scrollbar {
      height: 7px;
    }

    .showcase-grid::-webkit-scrollbar-thumb {
      border-radius: 999px;
      background: rgb(86 225 233 / 0.45);
    }

    .showcase-grid::-webkit-scrollbar-track {
      background: hsl(240 47% 47% / 0.08);
      border-radius: 999px;
    }

    .phone-wrap {
      flex: 0 0 86%;
      scroll-snap-align: center;
    }

    .phone-center .phone-frame {
      transform: none;
      width: min(100%, 340px);
    }

    .float-tag {
      position: static;
      display: inline-flex;
      margin: 0 auto 10px;
    }
  }
</style>
