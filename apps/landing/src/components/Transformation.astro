---
import type { LandingCopy } from "../i18n";

export interface Props {
  copy: LandingCopy;
}

const { copy } = Astro.props;

const BEFORE_ITEMS = copy.transformation.beforeItems;
const AFTER_ITEMS = copy.transformation.afterItems;

const statusStyles: Record<string, string> = {
  unpaid: "bg-destructive/10 text-destructive",
  disputed: "bg-primary/10 text-primary",
  unclear: "bg-secondary/10 text-secondary",
  forgot: "bg-muted text-muted-foreground",
};
---

<section
  id="how-it-works"
  data-transformation
  class="relative overflow-hidden py-24 md:py-32"
  style="background: hsl(252 33% 97%)"
>
  <div
    class="absolute -right-20 top-20 h-80 w-80 rounded-full opacity-[0.04]"
    style="background: hsl(240 47% 47%)"
  >
  </div>
  <div
    class="absolute -left-10 bottom-10 h-60 w-60 opacity-[0.03]"
    style="background: hsl(174 73% 48%); transform: rotate(45deg)"
  >
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="section-intro mb-16 max-w-2xl transition-all duration-1000">
      <span
        class="mb-4 inline-block rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-widest"
        style="background: hsl(240 47% 47% / 0.08); color: hsl(240 47% 47%)"
      >
        {copy.transformation.badge}
      </span>
      <h2
        class="font-display text-3xl font-bold leading-tight tracking-tight text-foreground md:text-5xl"
      >
        <span class="text-balance">
          {copy.transformation.titleStart}
          <span class="relative">
            {copy.transformation.titleChaos}
            <svg
              class="absolute -bottom-1 left-0 w-full"
              viewBox="0 0 120 8"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M2 6C30 2 80 2 118 6"
                stroke="hsl(0 84% 60%)"
                stroke-width="2"
                stroke-linecap="round"
                opacity="0.4"></path>
            </svg>
          </span>
          {copy.transformation.titleMiddle}
          <span style="color: hsl(174 73% 48%)">{copy.transformation.titleClarity}</span>
          {copy.transformation.titleEnd}
        </span>
      </h2>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      <div
        class="before-panel transition-all duration-1000"
        style="transition-delay: 200ms"
      >
        <div
          class="relative overflow-hidden rounded-2xl border-2 border-dashed p-6"
          style="border-color: hsl(0 84% 60% / 0.2); background: hsl(0 0% 100% / 0.5)"
        >
          <div class="mb-4 flex items-center gap-3">
            <div
              class="flex h-8 w-8 items-center justify-center rounded-lg text-sm font-bold"
              style="background: hsl(0 84% 60% / 0.1); color: hsl(0 84% 60%)"
            >
              ?
            </div>
            <span class="font-display text-lg font-semibold text-foreground"
              >{copy.transformation.beforeTitle}</span
            >
          </div>
          <div class="space-y-3">
            {
              BEFORE_ITEMS.map((item, i) => (
                <div
                  class="before-item flex items-center justify-between rounded-xl border bg-card p-3 transition-all duration-500"
                  data-index={i}
                  style={`transition-delay: ${300 + i * 100}ms`}
                >
                  <div class="flex items-center gap-3">
                    <div
                      class="flex h-8 w-8 items-center justify-center rounded-full text-xs font-semibold"
                      style="background: hsl(240 47% 47% / 0.1); color: hsl(240 47% 47%)"
                    >
                      {item.person[0]}
                    </div>
                    <div>
                      <p class="text-sm font-medium text-foreground">
                        {item.person}
                      </p>
                      <p class="text-xs text-muted-foreground">{item.note}</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-semibold text-foreground">
                      {item.amount}
                    </span>
                    <span
                      class={`rounded-full px-2 py-0.5 text-xs font-medium ${statusStyles[item.statusKey] || ""}`}
                    >
                      {item.statusLabel}
                    </span>
                  </div>
                </div>
              ))
            }
          </div>
          <svg
            class="absolute -right-2 top-1/2 -translate-y-1/2 opacity-10"
            width="20"
            height="120"
            viewBox="0 0 20 120"
            aria-hidden="true"
          >
            <path
              d="M10 0C15 20 5 40 10 60C15 80 5 100 10 120"
              stroke="hsl(0 84% 60%)"
              stroke-width="2"
              fill="none"></path>
          </svg>
        </div>
      </div>

      <div
        class="after-panel transition-all duration-1000"
        style="transition-delay: 500ms"
      >
        <div
          class="relative overflow-hidden rounded-2xl border-2 p-6"
          style="border-color: hsl(174 73% 48% / 0.3); background: hsl(174 73% 48% / 0.04)"
        >
          <div class="mb-4 flex items-center gap-3">
            <div
              class="flex h-8 w-8 items-center justify-center rounded-lg text-sm font-bold"
              style="background: hsl(174 73% 48% / 0.15); color: hsl(174 73% 48%)"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M3 8l3.5 3.5L13 5"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </div>
            <span class="font-display text-lg font-semibold text-foreground"
              >{copy.transformation.afterTitle}</span
            >
          </div>
          <div class="space-y-3">
            {
              AFTER_ITEMS.map((item, i) => (
                <div
                  class="after-item flex items-center justify-between rounded-xl border bg-card p-3 transition-all duration-500"
                  style={`transition-delay: ${600 + i * 150}ms`}
                >
                  <div class="flex items-center gap-3">
                    <div class="flex items-center gap-1">
                      <div
                        class="flex h-7 w-7 items-center justify-center rounded-full text-xs font-semibold"
                        style="background: hsl(240 47% 47% / 0.1); color: hsl(240 47% 47%)"
                      >
                        {item.from[0]}
                      </div>
                      <svg
                        width="16"
                        height="8"
                        viewBox="0 0 16 8"
                        fill="none"
                        aria-hidden="true"
                      >
                        <path
                          d="M0 4h12m0 0L9 1m3 3L9 7"
                          stroke="hsl(174 73% 48%)"
                          stroke-width="1.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                      <div
                        class="flex h-7 w-7 items-center justify-center rounded-full text-xs font-semibold"
                        style="background: hsl(174 73% 48% / 0.1); color: hsl(174 73% 48%)"
                      >
                        {item.to[0]}
                      </div>
                    </div>
                    <div>
                      <p class="text-sm font-medium text-foreground">
                        {item.from} -&gt; {item.to}
                      </p>
                    </div>
                  </div>
                  <div class="flex items-center gap-2">
                    <span
                      class="text-sm font-bold"
                      style="color: hsl(174 73% 48%)"
                    >
                      {item.amount}
                    </span>
                    {item.settled ? (
                      <span
                        class="rounded-full px-2 py-0.5 text-xs font-medium"
                        style="background: hsl(174 73% 48% / 0.1); color: hsl(174 73% 48%)"
                      >
                        {copy.transformation.settled}
                      </span>
                    ) : (
                      <span
                        class="rounded-full px-2 py-0.5 text-xs font-medium"
                        style="background: hsl(240 47% 47% / 0.08); color: hsl(240 47% 47%)"
                      >
                        {copy.transformation.pending}
                      </span>
                    )}
                  </div>
                </div>
              ))
            }
          </div>
          <div
            class="total-bar mt-4 flex items-center justify-between rounded-xl p-3 transition-all duration-700"
            style="background: hsl(174 73% 48% / 0.08); transition-delay: 1100ms"
          >
            <span class="text-sm font-medium text-muted-foreground"
              >{copy.transformation.everyoneSquare}</span
            >
            <span class="text-sm font-bold" style="color: hsl(174 73% 48%)">
              {copy.transformation.transfers}
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll("[data-transformation]").forEach((section) => {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) return;
        section.setAttribute("data-in-view", "true");
        observer.unobserve(section);
      },
      { threshold: 0.1 },
    );

    observer.observe(section);
  });
</script>

<style>
  [data-transformation] .section-intro {
    opacity: 0;
    transform: translateY(48px);
  }
  [data-transformation][data-in-view="true"] .section-intro {
    opacity: 1;
    transform: translateY(0);
  }

  [data-transformation] .before-panel {
    opacity: 0;
    transform: translateX(-48px);
  }
  [data-transformation][data-in-view="true"] .before-panel {
    opacity: 1;
    transform: translateX(0);
  }

  [data-transformation] .before-item {
    opacity: 0.6;
  }
  [data-transformation] .before-item[data-index="0"] {
    transform: rotate(-2deg) translateX(-10px);
  }
  [data-transformation] .before-item[data-index="1"] {
    transform: rotate(3deg) translateX(10px);
  }
  [data-transformation] .before-item[data-index="2"] {
    transform: rotate(-4deg) translateX(-10px);
  }
  [data-transformation] .before-item[data-index="3"] {
    transform: rotate(5deg) translateX(10px);
  }
  [data-transformation][data-in-view="true"] .before-item {
    opacity: 1;
    transform: none;
  }

  [data-transformation] .after-panel {
    opacity: 0;
    transform: translateX(48px);
  }
  [data-transformation][data-in-view="true"] .after-panel {
    opacity: 1;
    transform: translateX(0);
  }

  [data-transformation] .after-item {
    opacity: 0;
    transform: translateY(10px);
  }
  [data-transformation][data-in-view="true"] .after-item {
    opacity: 1;
    transform: none;
  }

  [data-transformation] .total-bar {
    opacity: 0;
  }
  [data-transformation][data-in-view="true"] .total-bar {
    opacity: 1;
  }
</style>
