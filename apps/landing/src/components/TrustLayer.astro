---
import type { LandingCopy } from "../i18n";

export interface Props {
  copy: LandingCopy;
}

const { copy } = Astro.props;
const stats = copy.trust.stats;
---

<script src="../scripts/in-view.ts"></script>

<section
  id="proof"
  data-trust-layer
  data-in-view-root
  class="relative overflow-hidden py-24 md:py-32"
  style="background: hsl(252 33% 97%)"
>
  <div
    class="absolute -top-20 right-1/4 h-40 w-40 opacity-[0.04]"
    style="background: hsl(240 47% 47%); border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%"
  >
  </div>
  <div
    class="absolute bottom-10 left-1/3 h-60 w-60 opacity-[0.03]"
    style="background: #56E1E9; border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%"
  >
  </div>

  <div class="mx-auto max-w-5xl px-6">
    <div class="section-intro mb-16 text-center transition-all duration-1000">
      <span
        class="mb-4 inline-block rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-widest"
        style="background: rgb(86 225 233 / 0.1); color: #56E1E9"
      >
        {copy.trust.badge}
      </span>
      <h2
        class="font-display text-3xl font-bold leading-tight tracking-tight text-foreground md:text-5xl"
      >
        <span class="text-balance">{copy.trust.title}</span>
      </h2>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {
        stats.map((stat, i) => (
          <div
            class={`stat-card group relative overflow-hidden rounded-2xl p-8 transition-all duration-700 hover:scale-[1.02] ${i === 1 ? "raise" : ""}`}
            data-raise={i === 1 ? "true" : "false"}
            style={`background: ${i === 1 ? "hsl(240 47% 47%)" : "hsl(0 0% 100%)"}; transition-delay: ${i * 150}ms`}
          >
            <div
              class="absolute -right-4 -top-4 h-24 w-24 rounded-full opacity-[0.06] transition-transform duration-500 group-hover:scale-150"
              style={`background: ${i === 1 ? "#56E1E9" : "hsl(240 47% 47%)"}`}
            />
            <div
              class="relative z-10 font-display text-4xl font-bold tracking-tight md:text-5xl"
              style={`color: ${i === 1 ? "white" : "hsl(240 47% 47%)"}`}
            >
              <span class="tabular-nums">
                {stat.displayValue}
              </span>
            </div>
            <p
              class="relative z-10 mt-3 font-display text-base font-semibold"
              style={`color: ${i === 1 ? "#56E1E9" : "hsl(240 38% 17%)"}`}
            >
              {stat.label}
            </p>
            <p
              class="relative z-10 mt-1 text-sm"
              style={`color: ${i === 1 ? "hsl(250 25% 90% / 0.6)" : "hsl(240 20% 46%)"}`}
            >
              {stat.sublabel}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script is:inline>
  const sections = document.querySelectorAll("[data-trust-layer]");

  sections.forEach((section) => {
    const counters = Array.from(section.querySelectorAll("[data-counter]"));
    const startCounter = (el) => {
      if (el.dataset.counting === "true") return;
      el.dataset.counting = "true";

      const end = Number(el.dataset.end || "0");
      const duration = Number(el.dataset.duration || "2000");
      const prefix = el.dataset.prefix || "";
      const suffix = el.dataset.suffix || "";
      const startTime = performance.now();

      const step = (now) => {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = Math.floor(eased * end);
        el.textContent = `${prefix}${value.toLocaleString()}${suffix}`;
        if (progress < 1) requestAnimationFrame(step);
      };

      requestAnimationFrame(step);
    };

    const triggerCounters = () => counters.forEach(startCounter);

    if (section.getAttribute("data-in-view") === "true") {
      triggerCounters();
      return;
    }

    const observer = new MutationObserver((mutations) => {
      for (const mutation of mutations) {
        if (
          mutation.type === "attributes" &&
          section.getAttribute("data-in-view") === "true"
        ) {
          triggerCounters();
          observer.disconnect();
          break;
        }
      }
    });

    observer.observe(section, {
      attributes: true,
      attributeFilter: ["data-in-view"],
    });
  });
</script>

<style>
  .section-intro {
    opacity: 0;
    transform: translateY(48px);
  }
  [data-trust-layer][data-in-view="true"] .section-intro {
    opacity: 1;
    transform: translateY(0);
  }

  .stat-card {
    opacity: 0;
    transform: translateY(24px);
  }
  [data-trust-layer][data-in-view="true"] .stat-card {
    opacity: 1;
    transform: translateY(0);
  }
  [data-trust-layer][data-in-view="true"] .stat-card[data-raise="true"] {
    transform: translateY(-24px);
  }

  @media (max-width: 767px) {
    [data-trust-layer][data-in-view="true"] .stat-card[data-raise="true"] {
      transform: translateY(0);
    }
  }
</style>
