---
import LandingPage from "../components/LandingPage.astro";
import { landingContent } from "../content/landing";
import Layout from "../layouts/Layout.astro";

const lang = "es";
const copy = landingContent[lang];
---

<Layout
  title={copy.layout.title}
  description={copy.layout.description}
  lang={lang}
  ogImageAlt={copy.layout.ogImageAlt}
  twitterImageAlt={copy.layout.twitterImageAlt}
>
  <LandingPage content={copy} />
</Layout>
