{
  "name": "@splitway/web",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "bun db:generate",
    "start": "bun run .output/server/index.mjs",
    "dev": "bun --bun vite dev",
    "build": "NODE_ENV=production bun --bun vite build",
    "compile": "bun build.ts",
    "check": "biome check --write",
    "clean": "rm -rf node_modules && rm -rf dist",
    "preview": "bun --bun vite preview",
    "db:generate": "dotenvx run -- prisma generate",
    "db:migrate:dev": "prisma migrate dev --name init",
    "db:migrate": "dotenvx run -- prisma migrate dev",
    "db:migrate:reset": "dotenvx run -- prisma migrate reset",
    "db:seed": "dotenvx run -- prisma db seed",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.4",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-query-devtools": "^5.84.2",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@workspace/ui": "workspace:*",
    "better-auth": "^1.4.12",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "nitro": "^3.0.1-alpha.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.8.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/devtools-vite": "^0.3.11",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript/native-preview": "latest",
    "@vitejs/plugin-react": "^5.0.4",
    "prisma": "^7.3.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^6.0.2",
    "web-vitals": "^5.1.0"
  }
}