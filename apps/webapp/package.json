{
  "name": "@vornway/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide && rsbuild build",
    "clean": "rm -rf node_modules && rm -rf dist",
    "check": "biome check --write",
    "dev": "portless app.vornway rsbuild --open",
    "deploy": "wrangler pages deploy --branch=main",
    "typecheck": "tsc --noEmit",
    "preview": "rsbuild preview",
    "machine-translate": "inlang machine translate --project project.inlang"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@tanstack/db": "^0.6.5",
    "@tanstack/query-core": "^5.100.11",
    "@tanstack/query-db-collection": "^1.0.36",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.168.25",
    "@vornway/api": "workspace:*",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "cnfast": "^0.0.8",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "html5-qrcode": "^2.3.8",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.14.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.5",
    "recharts": "3.8.0",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@inlang/cli": "^3.0.0",
    "@inlang/paraglide-js": "^2.18.1",
    "@rsbuild/core": "^2.1.1",
    "@rsbuild/plugin-react": "^2.1.0",
    "@rsbuild/plugin-tailwindcss": "^2.0.3",
    "@tanstack/router-plugin": "^1.167.28",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "portless": "catalog:",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
