{
  "name": "splitway",
  "private": true,
  "author": "Nestor Cortina <nexckycort@gmail.com>",
  "license": "MIT",
  "scripts": {
    "postinstall": "lefthook install",
    "clean:apps": "bun run -r --parallel --filter='./apps/*' clean",
    "clean:packages": "bun run -r --parallel --filter='./packages/*' clean",
    "clean": "bun run clean:apps & bun run clean:packages & rm -rf node_modules",
    "dev": "bun run -r --parallel --filter='./apps/*' dev"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "bun-types": "latest",
    "lefthook": "^2.0.12",
    "typescript": "catalog:",
    "@types/bun": "latest"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@biomejs/biome": "^2.3.9",
      "@types/node": "^24.10.1",
      "@typescript/native-preview": "latest",
      "typescript": "^5.9.3"
    }
  }
}