{
  "name": "vornway",
  "private": true,
  "author": "Nestor Cortina <nexckycort@gmail.com>",
  "license": "MIT",
  "scripts": {
    "postinstall": "lefthook install",
    "clean:apps": "bun run -r --parallel --filter='./apps/*' clean",
    "clean:packages": "bun run -r --parallel --filter='./packages/*' clean",
    "clean": "bun run clean:apps & bun run clean:packages & rm -rf node_modules",
    "dev": "mprocs -c mprocs/dev.yaml"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/bun": "latest",
    "@types/node": "catalog:",
    "bun-types": "latest",
    "lefthook": "^2.0.12",
    "mprocs": "^0.9.6",
    "typescript": "^7.0.2"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@biomejs/biome": "^2.4.14",
      "@prisma/adapter-pg": "^7.8.0",
      "@prisma/client": "^7.8.0",
      "@types/bun": "latest",
      "@types/node": "^24.10.1",
      "better-auth": "^1.6.9",
      "portless": "^0.15.2",
      "resend": "^6.12.2",
      "prisma": "^7.8.0",
      "hono": "^4.12.19",
      "tailwindcss": "^4.3.2",
      "tw-animate-css": "^1.4.0",
      "typescript": "^7.0.2",
      "zod": "^4.3.6",
      "wrangler": "^4.110.0"
    }
  }
}
