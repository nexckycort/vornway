model Itinerary {
  id        String         @id @default(cuid())
  userId    String
  city      String
  country   String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  days ItineraryDay[]

  @@index([userId, createdAt])
  @@map("itinerary")
}

model ItineraryDay {
  id            String                  @id @default(cuid())
  itineraryId   String
  dayNumber     Int
  date          DateTime
  transportMode String                  @default("walking")
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  itinerary      Itinerary               @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  places         ItineraryPlace[]
  note           ItineraryNote?
  checklistItems ItineraryChecklistItem[]

  @@unique([itineraryId, dayNumber])
  @@index([itineraryId, date])
  @@map("itinerary_day")
}

model ItineraryPlace {
  id                   String       @id @default(cuid())
  dayId                String
  name                 String
  type                 String
  imageUrl             String?
  description          String?
  latitude             Float
  longitude            Float
  openingHours         String?
  ticketRequired       Boolean      @default(false)
  price                Float?
  visitDurationMinutes Int          @default(90)
  orderIndex           Int
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  day ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId, orderIndex])
  @@map("itinerary_place")
}

model ItineraryNote {
  id        String      @id @default(cuid())
  dayId      String      @unique
  content    String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  day ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@map("itinerary_note")
}

model ItineraryChecklistItem {
  id         String      @id @default(cuid())
  dayId      String
  item       String
  completed  Boolean     @default(false)
  orderIndex Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  day ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId, orderIndex])
  @@map("itinerary_checklist_item")
}
